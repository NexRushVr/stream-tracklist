# Spotify integration (optional — needed for direct track links and --create-playlist).
# Create an app at https://developer.spotify.com/dashboard and set the redirect URI
# to http://127.0.0.1:8888/callback in the app settings.
SPOTIFY_CLIENT_ID=your_client_id_here
SPOTIFY_CLIENT_SECRET=your_client_secret_here
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback
